{
  "name": "repotools",
  "version": "1.0.0",
  "description": "Local-first repo utility dashboard for inspecting and working with a selected project folder.",
  "main": "server.js",
  "scripts": {
    "setup": "npm install && npm run build:css",
    "check": "npm test && npm run build:css",
    "dev": "node server.js",
    "start": "node server.js",
    "test": "node --test",
    "build:css": "tailwindcss -i ./src/styles/tailwind.css -o ./public/styles.css --minify",
    "watch:css": "tailwindcss -i ./src/styles/tailwind.css -o ./public/styles.css --watch"
  },
  "keywords": [
    "express",
    "ejs",
    "tailwind",
    "local",
    "repo-tools"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.17"
  }
}
